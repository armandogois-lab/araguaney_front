# ---- API ----
# Backend HOST (no /api suffix — paths in lib/api/ already include /api/...).
# Local dev: http://localhost:3001
# Production: https://araguaneyback-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Supabase Auth ----
# Public values — safe to ship in the browser bundle (ANON_KEY is designed for client use)
# Both come from Supabase Studio → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ---- Type generation ----
# Where to read the OpenAPI spec from when running `pnpm types:generate`.
# - Local repos side-by-side: ../araguaney_back/openapi.json
# - CI / fresh clone:         https://araguaneyback-production.up.railway.app/api/docs-json
OPENAPI_SOURCE=../araguaney_back/openapi.json
